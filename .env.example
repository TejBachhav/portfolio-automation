# Copy this file to .env and fill in any API keys you choose to use.
# The free pipeline doesn't need any of these — they're only for OPTIONAL upgrades.

# ─── OPTIONAL: Premium US fundamentals (Financial Modeling Prep) ──────────
# Sign up at https://financialmodelingprep.com (free tier: 250 calls/day)
FMP_API_KEY=

# ─── OPTIONAL: Alpha Vantage for backup US data ───────────────────────────
# Sign up at https://www.alphavantage.co/support/#api-key (free: 25 calls/day)
ALPHAVANTAGE_API_KEY=

# ─── OPTIONAL: Screener.in Premium API for Indian fundamentals ────────────
# Plans starting at ~₹1,500/month — only needed if you want PEG, FII/DII chg,
# 5-year growth variance, intrinsic value for Nifty 500
SCREENER_API_KEY=

# ─── Pipeline behavior ────────────────────────────────────────────────────
ENABLE_SCREENER_SCRAPE=false
RATE_LIMIT_SECONDS=0.3
RISK_FREE_RATE=0.065
